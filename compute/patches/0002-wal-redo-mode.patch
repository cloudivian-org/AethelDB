diff --git a/src/include/access/walredo.h b/src/include/access/walredo.h
new file mode 100644
index 0000000..bc112a0
--- /dev/null
+++ b/src/include/access/walredo.h
@@ -0,0 +1,25 @@
+/*-------------------------------------------------------------------------
+ *
+ * walredo.h
+ *	  AethelDB wal-redo backend: apply WAL records to a page out-of-process.
+ *
+ * SPDX-License-Identifier: Apache-2.0
+ * Copyright 2026 The AethelDB Authors
+ *
+ * src/include/access/walredo.h
+ *
+ *-------------------------------------------------------------------------
+ */
+#ifndef WALREDO_H
+#define WALREDO_H
+
+/* True when this backend was started as `postgres --wal-redo`. */
+extern PGDLLIMPORT bool am_wal_redo;
+
+/*
+ * Run the wal-redo protocol loop. Called from PostgresMain() after standard
+ * single-user initialization, in place of the SQL command loop. Never returns.
+ */
+extern void WalRedoMain(void) pg_attribute_noreturn();
+
+#endif							/* WALREDO_H */
